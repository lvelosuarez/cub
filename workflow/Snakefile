import os
from collections import defaultdict

import pandas as pd


def get_sample_df() -> pd.DataFrame:
    """
    Extract samples from NGS Illumina folder.

    Handles:
      - MG-Run35-Ech-9_S9_L004_R1_001.fastq.gz
      - CasClinique3_ADN_R1.fastq.gz
      - Any *.fastq, *.fastq.gz, *.fq, *.fq.gz

    Columns created:
      - index       : lane-level ID (used as "names")
      - sample      : biological sample for old data (MG-Run35-Ech-9)
      - lane        : lane info for old data (S9_L004)
      - names       : same as index, used by wildcards.names
      - sample_core : unified sample ID (sample if available, else names)
      - R1 / R2     : raw fastq paths
    """
    path = os.getcwd()
    samples = defaultdict(dict)
    excluded_dirs = {"output", "results"}

    for dirpath, dirnames, files in os.walk(os.path.abspath(path)):
        # Do not go into output/results folders
        dirnames[:] = [d for d in dirnames if d not in excluded_dirs]

        for fname in files:
            # Only fastq/fq files (gz or not)
            if not fname.endswith((".fastq", ".fastq.gz", ".fq", ".fq.gz")):
                continue

            # Remove extension
            stem = fname
            for suf in (".fastq.gz", ".fq.gz", ".fastq", ".fq"):
                if stem.endswith(suf):
                    stem = stem[: -len(suf)]
                    break

            # Remove read and illumina suffixes to get the sample_id
            # Examples:
            #   MG-Run35-Ech-9_S9_L004_R1_001 -> MG-Run35-Ech-9_S9_L004
            #   CasClinique3_ADN_R1           -> CasClinique3_ADN
            sample_id = (
                stem
                .replace("_R1_001", "")
                .replace("_R2_001", "")
                .replace("_R1", "")
                .replace("_R2", "")
                .replace(" ", "-")
            )

            fq_path = os.path.join(dirpath, fname)

            if "_R1" in fname:
                samples[sample_id]["R1"] = fq_path
            elif "_R2" in fname:
                samples[sample_id]["R2"] = fq_path

    # Build DataFrame
    df = pd.DataFrame.from_dict(samples, orient="index")
    df.index.name = "index"
    df = df.reset_index()

    # For old Illumina-style names MG-Run35-Ech-9_S9_L004
    df["sample"] = df["index"].str.extract(r"^(.+)_S\d+_L\d+$", expand=False)
    df["lane"] = df["index"].str.extract(r"^.+_(S\d+_L\d+)$", expand=False)

    # Lane-level name used by wildcards.names
    df["names"] = df["index"]

    # Unified biological sample ID:
    # - old data: MG-Run35-Ech-9
    # - new data: CasClinique3_ADN (because sample is NaN)
    df["sample_core"] = df["sample"].fillna(df["names"])

    # Remove Undetermined* if present
    df = df[~df["names"].str.startswith("Undet")]

    return df


# Build global tables
SAMPLES = get_sample_df()
SAMPLE_CORES = sorted(SAMPLES["sample_core"].unique())


def get_raw_fastq(names: str) -> dict:
    """
    Return raw fastq path(s) for a given lane-level 'names'.

    Used by the qc rule (per lane).
    """
    subset = SAMPLES.loc[SAMPLES["names"] == names]

    if subset.empty:
        raise ValueError(f"No sample found in SAMPLES for names == {names!r}")

    def _clean(col):
        # Keep only non-empty strings (drop NaN and blanks)
        return [
            v for v in col.tolist()
            if isinstance(v, str) and v.strip() != ""
        ]

    r1 = _clean(subset["R1"])
    r2 = _clean(subset["R2"])

    import sys
    print(f"[DEBUG] get_raw_fastq({names!r}) -> R1={r1}, R2={r2}", file=sys.stderr)

    if not r1 or not r2:
        raise ValueError(
            f"Missing R1 or R2 for lane {names}.\n"
            f"SAMPLES rows:\n{subset[['names','R1','R2']]}"
        )

    return {"r1": r1, "r2": r2}


def get_dehost_fastq_for_sample(sample: str) -> dict:
    """
    Return dehosted fastq paths for a biological sample (possibly multiple lanes).

    Input pattern (lane-level):
      output/dehost/{names}_dedup_R1.clean_1.fastq.gz

    Grouped by:
      SAMPLES.sample_core
    """
    subset = SAMPLES.loc[SAMPLES["sample_core"] == sample]

    if subset.empty:
        raise ValueError(f"No rows in SAMPLES for sample_core == {sample!r}")

    r1 = [f"output/dehost/{n}_dedup_R1.clean_1.fastq.gz" for n in subset["names"]]
    r2 = [f"output/dehost/{n}_dedup_R2.clean_2.fastq.gz" for n in subset["names"]]

    import sys
    print(f"[DEBUG] get_dehost_fastq_for_sample({sample!r}) -> R1={r1}, R2={r2}", file=sys.stderr)

    return {"r1": r1, "r2": r2}


